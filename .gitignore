# ── Virtual Environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Python Cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ── Coverage & Testing ────────────────────────────────────────────────────────
.early.coverage/
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.tox/

# ── Model Cache (HuggingFace downloads — large files, don't commit) ───────────
.cache/
*.gguf
*.safetensors
*.bin
*.pt
*.pth

# ── Sensitive / Bank Statement PDFs (never commit customer data) ──────────────
*.pdf
*.PDF

# ── Temp Files ────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.log

# ── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo
*~

# ── Environment Variables ─────────────────────────────────────────────────────
# .env
# .env.*
# !.env.example

# ── Build / Distribution ─────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
wheels/

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Windows specific ─────────────────────────────────────────────────────────
$RECYCLE.BIN/
